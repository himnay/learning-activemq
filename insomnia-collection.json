{
  "_type": "export",
  "__export_format": 4,
  "__export_date": "2026-07-17T00:00:00.000Z",
  "__export_source": "learning-activemq",
  "resources": [
    {
      "_id": "wrk_learning_activemq",
      "_type": "workspace",
      "name": "Learning ActiveMQ",
      "description": "Event-driven REST publisher + JMS consumer over ActiveMQ Classic topics"
    },

    {
      "_id": "fld_publisher",
      "_type": "request_group",
      "parentId": "wrk_learning_activemq",
      "name": "Publisher — REST API (port 8080)",
      "description": "Publishes typed events to orders.topic / payments.topic / shipments.topic"
    },

    {
      "_id": "req_post_order_event",
      "_type": "request",
      "parentId": "fld_publisher",
      "name": "POST — Publish OrderCreatedEvent",
      "method": "POST",
      "url": "http://localhost:8080/v1/events/orders",
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"product\": \"Laptop\",\n  \"quantity\": 2,\n  \"amount\": 2499.98\n}"
      }
    },

    {
      "_id": "req_post_payment_event",
      "_type": "request",
      "parentId": "fld_publisher",
      "name": "POST — Publish PaymentReceivedEvent",
      "method": "POST",
      "url": "http://localhost:8080/v1/events/payments",
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"orderId\": \"replace-with-orderId\",\n  \"amount\": 2499.98,\n  \"method\": \"CARD\"\n}"
      }
    },

    {
      "_id": "req_post_shipment_event",
      "_type": "request",
      "parentId": "fld_publisher",
      "name": "POST — Publish ShipmentDispatchedEvent",
      "method": "POST",
      "url": "http://localhost:8080/v1/events/shipments",
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"orderId\": \"replace-with-orderId\",\n  \"carrier\": \"DHL\",\n  \"trackingNumber\": \"DHL-123456\"\n}"
      }
    },

    {
      "_id": "req_publisher_health",
      "_type": "request",
      "parentId": "fld_publisher",
      "name": "GET — Publisher Health",
      "method": "GET",
      "url": "http://localhost:8080/actuator/health"
    },

    {
      "_id": "fld_consumer",
      "_type": "request_group",
      "parentId": "wrk_learning_activemq",
      "name": "Consumer — Actuator (port 8081)",
      "description": "Consumer has no business endpoints — events arrive via JMS listeners"
    },

    {
      "_id": "req_consumer_health",
      "_type": "request",
      "parentId": "fld_consumer",
      "name": "GET — Consumer Health",
      "method": "GET",
      "url": "http://localhost:8081/actuator/health"
    }
  ]
}
